server {
    server_name techmasterai.in  www.techmasterai.in;

    root /var/www/my-app/dist; # Path to your React Build folder
    index index.html;

    # Serve React Frontend
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API requests to Node/Express
    location /api {
        proxy_pass http://localhost:3001; # Matches the PORT in your backend .env
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/techmasterai.in/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/techmasterai.in/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}
server {
    if ($host = www.techmasterai.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = techmasterai.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name techmasterai.in  www.techmasterai.in;
    return 404; # managed by Certbot



